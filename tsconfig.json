{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2024"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "dist",
        "rootDir": "src",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": false
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist", "**/__tests__/**", "**/__mocks__/**", "**/*.test.ts"]
}
